# Copy to .env and fill in. NEVER commit the real .env.

# ── Front (Vite) ──────────────────────────────────────────────
# Backend adapter: mock (default, no backend needed) | supabase
VITE_DATA_BACKEND=mock
# Supabase project (Settings → API) — only needed when VITE_DATA_BACKEND=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Migration script + admin (server-side only) ───────────────
SUPABASE_URL=
# Settings → API → service_role key (bypasses RLS — keep secret)
SUPABASE_SERVICE_ROLE_KEY=
# Settings → Database → connection string (for TRUNCATE/setval)
SUPABASE_DB_URL=

# ── SharePoint source (Azure AD App Registration, application permission Sites.Read.All) ──
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
SP_SITE_URL=https://sumardigital.sharepoint.com/sites/TopRentals

# ── Emails (later phase — Microsoft Graph Mail.Send) ──────────
# Sender mailbox for transactional emails
MAIL_SENDER=
# Replaces the hardcoded BCC list from the PowerApps hidden label
NOTIFICATIONS_BCC=
